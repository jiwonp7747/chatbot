# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# ── OpenAI ──
OPENAI_API_KEY=your-openai-api-key
OPENAI_PROVIDER=openai
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=30

# ── Google Gemini (optional) ──
GOOGLE_API_KEY=your-google-api-key

# ── OCI Generative AI (optional) ──
# OCI_CONFIG_FILE=~/.oci/config
# OCI_CONFIG_PROFILE=DEFAULT
# OCI_COMPARTMENT_ID=your-compartment-id
# OCI_MODEL_ID=meta.llama-3.3-70b-instruct

# ── OpenRouter (optional) ──
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Fab Trace API (optional) ──
FAB_TRACE_API_URL=http://localhost:8080

# ── MCP Server ──
MCP_SERVER_SSE_URL=http://localhost:3000/sse

# ── JWT ──
TOKEN_SECRET_KEY=your-jwt-secret-key

# ── OpenTelemetry (optional) ──
OTEL_ENABLED=false
OTEL_SERVICE_NAME=chat-backend
OTEL_COLLECTOR_BASE_URL=http://localhost:4318
